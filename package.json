{
  "name": "vuln-chain-detector",
  "version": "0.1.0",
  "description": "Static analysis engine for detecting chained vulnerability paths and zero-day exploit chains",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "scan": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "commander": "^12.0.0",
    "js-yaml": "^4.1.0",
    "tree-sitter": "^0.21.0",
    "tree-sitter-typescript": "^0.21.0",
    "tree-sitter-javascript": "^0.21.0"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "security",
    "sast",
    "vulnerability",
    "chain",
    "taint-analysis",
    "zero-day",
    "cve"
  ]
}
